{
  "name": "digitaldev-lx/laravel-eupago",
  "description": "A Laravel package for making payments through the EuPago API.",
  "keywords": [
    "eupago",
    "referências multibanco",
    "mb references",
    "mbway references",
    "laravel-eupago",
    "laravel",
    "codetech"
  ],
  "authors": [
    {
      "name": "DigitalDev",
      "email": "geral@digitaldev.pt",
      "role": "Development Team"
    }
  ],
  "license": "MIT",
  "require": {
    "php": "^8.3 || ^8.4",
    "laravel/framework": "^11.0 || ^12.0",
    "opcodesio/log-viewer": "^3.10"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0 || ^10.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0",
    "larastan/larastan": "^3.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "DigitaldevLx\\LaravelEupago\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DigitaldevLx\\LaravelEupago\\Tests\\": "tests/",
      "DigitaldevLx\\LaravelEupago\\Database\\Factories\\": "database/factories/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "test": "vendor/bin/pest",
    "test:coverage": "vendor/bin/pest --coverage --min=80",
    "analyse": "vendor/bin/phpstan analyse"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "DigitaldevLx\\LaravelEupago\\Providers\\EuPagoServiceProvider"
      ]
    }
  }
}
